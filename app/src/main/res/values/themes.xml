<resources>

    <!-- Main App Theme -->
    <style name="Theme.UberClone" parent="Theme.Material3.Light.NoActionBar">
        <!-- Brand Colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorAccent</item>

        <!-- System Bars -->
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/colorBackground</item>

        <item name="android:windowDisablePreview">true</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.UberClone.Splash"
        parent="Theme.Material3.Light.NoActionBar">

        <item name="android:windowFullscreen">true</item>

        <!-- We'll replace this with our custom splash layout later -->
        <item name="android:windowBackground">@color/white</item>

        <item name="android:statusBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>

    </style>

    <!-- Firebase Login -->
    <style name="LoginTheme" parent="FirebaseUI">

        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

    </style>

    <!-- Full Screen Registration Dialog -->
    <style name="DialogTheme" parent="Theme.Material3.Light.Dialog">

        <item name="android:windowBackground">@color/white</item>

        <item name="android:windowNoTitle">true</item>

        <item name="android:windowIsFloating">false</item>

        <item name="android:layout_width">match_parent</item>

        <item name="android:layout_height">match_parent</item>

    </style>

    <!-- No ActionBar Theme -->
    <style name="Theme.UberClone.NoActionBar"
        parent="Theme.Material3.Light.NoActionBar">

        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorAccent</item>

        <item name="android:statusBarColor">@color/black</item>

        <item name="android:navigationBarColor">@color/black</item>

        <item name="android:windowLightStatusBar">false</item>

    </style>

    <!-- Toolbar Overlay -->
    <style name="Theme.UberClone.AppBarOverlay"
        parent="ThemeOverlay.Material3.Dark.ActionBar" />

    <!-- Popup Overlay -->
    <style name="Theme.UberClone.PopupOverlay"
        parent="ThemeOverlay.Material3.Light" />

</resources>






















